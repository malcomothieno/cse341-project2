{
  "swagger": "2.0",
  "info": {
    "title": "Movie Database API",
    "description": "RESTful API for managing a movie database. Full CRUD on Movies (8 fields) and Directors. POST, PUT, DELETE routes are protected and require GitHub OAuth authentication.",
    "version": "1.0.0"
  },
  "host": "cse341-project2-huok.onrender.com",
  "schemes": ["https"],
  "securityDefinitions": {
    "githubOAuth": {
      "type": "oauth2",
      "authorizationUrl": "https://cse341-project2-huok.onrender.com/auth/github",
      "flow": "implicit",
      "scopes": {
        "user:email": "Read user email"
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "GitHub OAuth login, logout, and profile" },
    { "name": "Movies", "description": "Movie records — 8 fields. GET is public. POST/PUT/DELETE require login." },
    { "name": "Directors", "description": "Director records. GET is public. POST/PUT/DELETE require login." }
  ],
  "paths": {
    "/auth/github": {
      "get": {
        "tags": ["Auth"],
        "summary": "Login with GitHub",
        "description": "Redirects the user to GitHub to authenticate via OAuth. After successful login, the user is redirected to /auth/profile.",
        "responses": {
          "302": { "description": "Redirects to GitHub OAuth page" }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Auth"],
        "summary": "View logged-in user profile",
        "description": "Returns the currently authenticated user's GitHub profile info. Returns 401 if not logged in.",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "User is logged in",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "You are logged in" },
                "user": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "username": { "type": "string", "example": "malcomothieno" },
                    "displayName": { "type": "string", "example": "Malcom Othieno" }
                  }
                }
              }
            }
          },
          "401": { "description": "Not logged in" }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Auth"],
        "summary": "Logout",
        "description": "Logs the current user out and destroys their session.",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },
    "/movies": {
      "get": {
        "tags": ["Movies"],
        "summary": "Get all movies (public)",
        "description": "Retrieves all documents from the MongoDB movies collection. No authentication required.",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "Array of movie objects", "schema": { "type": "array", "items": { "$ref": "#/definitions/Movie" } } },
          "500": { "description": "Internal server error" }
        }
      },
      "post": {
        "tags": ["Movies"],
        "summary": "Create a new movie (protected)",
        "description": "Adds a new movie. All 8 fields required. Requires GitHub OAuth login — visit /auth/github first.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "in": "body", "name": "body", "required": true, "description": "Movie object — all 8 fields required", "schema": { "$ref": "#/definitions/MovieInput" } }
        ],
        "responses": {
          "201": {
            "description": "Movie created successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "Movie created successfully" },
                "id": { "type": "string", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
              }
            }
          },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized — login required" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/movies/{id}": {
      "get": {
        "tags": ["Movies"],
        "summary": "Get a movie by ID (public)",
        "description": "Retrieves a single movie by its MongoDB ObjectId. No authentication required.",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
        ],
        "responses": {
          "200": { "description": "Movie found", "schema": { "$ref": "#/definitions/Movie" } },
          "400": { "description": "Invalid ID format" },
          "404": { "description": "Movie not found" }
        }
      },
      "put": {
        "tags": ["Movies"],
        "summary": "Update a movie by ID (protected)",
        "description": "Updates fields on an existing movie. Requires GitHub OAuth login — visit /auth/github first.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId of the movie to update", "example": "665f1a2b3c4d5e6f7a8b9c0d" },
          { "in": "body", "name": "body", "required": true, "description": "Fields to update", "schema": { "$ref": "#/definitions/MovieInput" } }
        ],
        "responses": {
          "200": { "description": "Movie updated successfully" },
          "400": { "description": "Validation failed or invalid ID" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Movie not found" }
        }
      },
      "delete": {
        "tags": ["Movies"],
        "summary": "Delete a movie by ID (protected)",
        "description": "Permanently removes a movie. Requires GitHub OAuth login — visit /auth/github first.",
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId of the movie to delete", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
        ],
        "responses": {
          "200": { "description": "Movie deleted successfully" },
          "400": { "description": "Invalid ID format" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Movie not found" }
        }
      }
    },
    "/directors": {
      "get": {
        "tags": ["Directors"],
        "summary": "Get all directors (public)",
        "description": "Retrieves all documents from the MongoDB directors collection. No authentication required.",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "Array of director objects", "schema": { "type": "array", "items": { "$ref": "#/definitions/Director" } } },
          "500": { "description": "Internal server error" }
        }
      },
      "post": {
        "tags": ["Directors"],
        "summary": "Create a new director (protected)",
        "description": "Adds a new director. All 5 fields required. Requires GitHub OAuth login — visit /auth/github first.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "in": "body", "name": "body", "required": true, "description": "Director object — all fields required", "schema": { "$ref": "#/definitions/DirectorInput" } }
        ],
        "responses": {
          "201": {
            "description": "Director created successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "Director created successfully" },
                "id": { "type": "string", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
              }
            }
          },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized — login required" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/directors/{id}": {
      "get": {
        "tags": ["Directors"],
        "summary": "Get a director by ID (public)",
        "description": "Retrieves a single director by their MongoDB ObjectId. No authentication required.",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
        ],
        "responses": {
          "200": { "description": "Director found", "schema": { "$ref": "#/definitions/Director" } },
          "400": { "description": "Invalid ID format" },
          "404": { "description": "Director not found" }
        }
      },
      "put": {
        "tags": ["Directors"],
        "summary": "Update a director by ID (protected)",
        "description": "Updates fields on an existing director. Requires GitHub OAuth login — visit /auth/github first.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId of the director to update", "example": "665f1a2b3c4d5e6f7a8b9c0d" },
          { "in": "body", "name": "body", "required": true, "description": "Fields to update", "schema": { "$ref": "#/definitions/DirectorInput" } }
        ],
        "responses": {
          "200": { "description": "Director updated successfully" },
          "400": { "description": "Validation failed or invalid ID" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Director not found" }
        }
      },
      "delete": {
        "tags": ["Directors"],
        "summary": "Delete a director by ID (protected)",
        "description": "Permanently removes a director. Requires GitHub OAuth login — visit /auth/github first.",
        "produces": ["application/json"],
        "security": [{ "githubOAuth": ["user:email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "MongoDB ObjectId of the director to delete", "example": "665f1a2b3c4d5e6f7a8b9c0d" }
        ],
        "responses": {
          "200": { "description": "Director deleted successfully" },
          "400": { "description": "Invalid ID format" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Director not found" }
        }
      }
    }
  },
  "definitions": {
    "Movie": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "665f1a2b3c4d5e6f7a8b9c0d" },
        "title": { "type": "string", "example": "Inception" },
        "genre": { "type": "string", "example": "Sci-Fi" },
        "releaseYear": { "type": "integer", "example": 2010 },
        "rating": { "type": "number", "example": 8.8 },
        "durationMinutes": { "type": "integer", "example": 148 },
        "language": { "type": "string", "example": "English" },
        "synopsis": { "type": "string", "example": "A thief who steals corporate secrets through dream-sharing technology." },
        "directorName": { "type": "string", "example": "Christopher Nolan" }
      }
    },
    "MovieInput": {
      "type": "object",
      "required": ["title", "genre", "releaseYear", "rating", "durationMinutes", "language", "synopsis", "directorName"],
      "properties": {
        "title": { "type": "string", "example": "Inception" },
        "genre": { "type": "string", "example": "Sci-Fi" },
        "releaseYear": { "type": "integer", "example": 2010 },
        "rating": { "type": "number", "example": 8.8 },
        "durationMinutes": { "type": "integer", "example": 148 },
        "language": { "type": "string", "example": "English" },
        "synopsis": { "type": "string", "example": "A thief who steals corporate secrets through dream-sharing technology." },
        "directorName": { "type": "string", "example": "Christopher Nolan" }
      }
    },
    "Director": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "665f1a2b3c4d5e6f7a8b9c0d" },
        "firstName": { "type": "string", "example": "Christopher" },
        "lastName": { "type": "string", "example": "Nolan" },
        "nationality": { "type": "string", "example": "British-American" },
        "birthYear": { "type": "integer", "example": 1970 },
        "knownFor": { "type": "string", "example": "Inception, The Dark Knight, Interstellar" }
      }
    },
    "DirectorInput": {
      "type": "object",
      "required": ["firstName", "lastName", "nationality", "birthYear", "knownFor"],
      "properties": {
        "firstName": { "type": "string", "example": "Christopher" },
        "lastName": { "type": "string", "example": "Nolan" },
        "nationality": { "type": "string", "example": "British-American" },
        "birthYear": { "type": "integer", "example": 1970 },
        "knownFor": { "type": "string", "example": "Inception, The Dark Knight, Interstellar" }
      }
    }
  }
}
